direction: right
produkte: {
  shape: sql_table

  produkt_id: String {constraint: primary_key}
  name: String
  sorte: String?
  hauptkategorie: String
  unterkategorie: String?
  lebensdauer: String?
  fruchtfolge_vor: "String[]"
  fruchtfolge_nach: "String[]"
  bodenansprueche: "String[]"
  begleitpflanzen: "String[]"
  saisonalitaet: "int[]"
  bild_datei_id: String?
  notizen: Text?
}

angebote: {
  shape: sql_table

  angebot_id: String {constraint: primary_key}
  produkt: produkte.produkt_id {constraint: relationship}
  jahr: int
  saat_pflanz_datum: timestamp?
  ernte_projektion: "timestamp[]"
  menge: double?
  menge_verfuegbar: double
  menge_reserviert: double
  einheit: Enum(stueck|kilogramm|bund|liter)
  preis_pro_einheit_eur: double
  teilungen: "double[]"
  preise_pro_teilung_eur: "double[]"
  erzeugerpreis_eur: double?
  standardpreis_eur: double?
  mitgliedspreis_eur: double?
  erwarteter_umsatz_eur: double?
  abholung_ab: timestamp?
  beschreibung: Text?
}

mitgliedschaften: {
  shape: sql_table

  mitgliedschaft_id: String {constraint: primary_key}
  benutzer_id: String {constraint: foreign_key}
  mitgliedsnummer: String
  mitgliedschaftstyp: Enum(privat|betrieb)
  dauer_jahre: int
  beantragt_am: date
  status: Enum(beantragt|aktiv|abgelaufen|storniert)
  bezahl_status: Enum(beantragt|teilbezahlt|bezahlt)
  bezahlt_am: date?
  startet_am: date?
  endet_am: date?
  letzte_erinnerung_am: date?
  guthaben_start_eur: double?
  guthaben_aktuell_eur: double?
  rechnungsadresse: Text?
  letzte_zahlung_id: String?
}

mitgliedschaftszahlungen: {
  shape: sql_table

  zahlung_id: String {constraint: primary_key}
  mitgliedschaft: mitgliedschaften.mitgliedschaft_id {constraint: relationship}
  zahlungsart: Enum(mitgliedschaft|bestellung|sonstiges)
  kundentyp: Enum(privat|betrieb)?
  betrag_eur: double
  status: Enum(offen|warten|bezahlt|fehlgeschlagen|storniert)
  referenz: String?
  notiz: Text?
  verifiziert_am: timestamp?
  faellig_am: timestamp?
}

bestellungen: {
  shape: sql_table

  bestellung_id: String {constraint: primary_key}
  benutzer_id: String {constraint: foreign_key}
  benutzer_email: String?
  mitgliedschaft: mitgliedschaften.mitgliedschaft_id {constraint: relationship}
  angebot: angebote.angebot_id {constraint: relationship}
  menge: double
  einheit: Enum(stueck|kilogramm|bund|liter)
  preis_pro_einheit_eur: double
  bestellte_teilungen: "double[]"
  bestellte_teilungs_anzahlen: "int[]"
  bestellte_teilpreise_eur: "double[]"
  gesamtpreis_eur: double
  abholung_ab: timestamp?
  produkt_name: String
  status: Enum(angefragt|bestaetigt|erfuellt|storniert)
}

user: {
  shape: sql_table

  user_id: String {constraint: primary_key}
  email: String {constraint: unique}
  user_label: Enum(none|admin|dev|privatKunde|businessKunde)
}

produkte -> angebote: hat {
  source-arrowhead: 1
  target-arrowhead: N
}

bestellungen -> mitgliedschaften: gehört zu {
  source-arrowhead: N
  target-arrowhead: 1
}

bestellungen -> angebote: besteht aus {
  source-arrowhead: N
  target-arrowhead: 1
}

mitgliedschaftszahlungen -> mitgliedschaften: gehört zu {
  source-arrowhead: N
  target-arrowhead: 1
}

user -> mitgliedschaften: hat {
  source-arrowhead: 1
  target-arrowhead: N
}
