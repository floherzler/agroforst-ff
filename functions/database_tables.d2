direction: right
products: {
  shape: sql_table

  product_id: String {constraint: primary_key}
  name: String
  variety: String?
  category: String
  subcategory: String?
  lifespan: String?
  crop_rotation_before: "String[]"
  crop_rotation_after: "String[]"
  soil_requirements: "String[]"
  companion_plants: "String[]"
  seasonality_months: "int[]"
  image_file_id: String?
  notes: Text?
}

offers: {
  shape: sql_table

  offer_id: String {constraint: primary_key}
  product: products.product_id {constraint: relationship}
  year: int
  sowing_date: timestamp?
  harvest_projection: "timestamp[]"
  projected_quantity: double?
  available_quantity: double
  allocated_quantity: double
  unit: Enum(piece|gram|bundle|liter)
  unit_price_eur: double
  producer_price_eur: double?
  standard_price_eur: double?
  member_price_eur: double?
  expected_revenue_eur: double?
  pickup_at: timestamp?
  description: Text?
}

memberships: {
  shape: sql_table

  membership_id: String {constraint: primary_key}
  user_id: String {constraint: foreign_key}
  membership_number: String
  membership_type: Enum(private|business)
  duration_years: int
  requested_at: date
  status: Enum(pending|active|expired|cancelled)
  payment_status: Enum(pending|partial|paid)
  paid_at: date?
  starts_at: date?
  ends_at: date?
  last_reminder_at: date?
  credit_start_eur: double?
  credit_balance_eur: double?
  billing_address: Text?
  last_payment_id: String?
}

membership_payments: {
  shape: sql_table

  payment_id: String {constraint: primary_key}
  membership: memberships.membership_id {constraint: relationship}
  payment_type: Enum(membership|order|other)
  customer_type: Enum(private|business)?
  amount_eur: double
  status: Enum(open|pending|paid|failed|cancelled)
  reference: String?
  note: Text?
  verified_at: timestamp?
  due_at: timestamp?
}

orders: {
  shape: sql_table

  order_id: String {constraint: primary_key}
  user_id: String {constraint: foreign_key}
  user_email: String?
  membership: memberships.membership_id {constraint: relationship}
  offer: offers.offer_id {constraint: relationship}
  quantity: double
  unit: Enum(piece|gram|bundle|liter)
  unit_price_eur: double
  total_price_eur: double
  pickup_at: timestamp?
  product_name: String
  status: Enum(requested|confirmed|fulfilled|cancelled)
}

user: {
  shape: sql_table

  user_id: String {constraint: primary_key}
  email: String {constraint: unique}
  user_label: Enum(none|admin|dev|privatKunde|businessKunde)
}

products -> offers: hat {
  source-arrowhead: 1
  target-arrowhead: N
}

orders -> memberships: gehört zu {
  source-arrowhead: N
  target-arrowhead: 1
}

orders -> offers: besteht aus {
  source-arrowhead: N
  target-arrowhead: 1
}

membership_payments -> memberships: gehört zu {
  source-arrowhead: N
  target-arrowhead: 1
}

user -> memberships: hat {
  source-arrowhead: 1
  target-arrowhead: N
}
