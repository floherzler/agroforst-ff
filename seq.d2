direction: right

User→Server Flows: {
  Sign-up (Account erstellen): {
    shape: sequence_diagram
    user: Benutzer
    web: Website (Next.js)
    auth: Appwrite Auth

    user -> web: Öffnet /signup
    web -> auth: POST account.create(email, password)
    auth -> web: OK (userId, session)
    web -> user: Eingeloggt

    web -> auth: (optional) account.createVerification()
    auth -> user: E-Mail mit Verifizierungslink
  }

  Mitgliedschaft beantragen: {
    shape: sequence_diagram
    user: Benutzer
    web: Website (Next.js)
    fn: Cloud Function createMembership
    db: Appwrite TablesDB

    user -> web: Klickt Mitgliedschaft beantragen
    web -> fn: POST createMembership(type)
    fn -> db: createRow(membership, pending, user_id)
    fn -> db: createRow(payment) bei private
    db -> fn: membership angelegt
    fn -> web: membership payload
    web -> user: Bestätigung "beantragt"
  }

  Angebot bestellen: {
    shape: sequence_diagram
    user: Benutzer
    web: Website (Next.js)
    fn: Cloud Function createOrder
    db: Appwrite Databases
    msg: Appwrite Messaging
    storage: Appwrite Storage
    inv: (optional) Cloud Function generateInvoice

    user -> web: Wählt Angebot & klickt Bestellen
    web -> fn: POST createOrder(offer, membership, quantity) + userId Header
    fn -> db: getRow(membership)
    db -> fn: Mitgliedschaft (Status/Guthaben)
    fn -> db: getRow(offer)
    db -> fn: Angebot (Preis/Einheit/Menge)

    fn -> db: Prüfe aktive Mitgliedschaft & Verfügbarkeit
    fn -> db: updateRow(offer, available -= menge, allocated += menge)
    fn -> db: createRow(order, membership relation, offer relation, snapshot fields)

    fn -> web: 201 orderId, preis_gesamt
    web -> user: Erfolgsanzeige & Zusammenfassung

    fn -> msg: (optional) Bestellbestätigung an Nutzer/Admin
    fn -> inv: (optional) Trigger generateInvoice(orderId)
    inv -> storage: (optional) PDF speichern
    inv -> msg: (optional) E-Mail mit PDF/Link
  }

  "Sign-up (Account erstellen)" -> "Mitgliedschaft beantragen": Nutzer eingeloggt
  "Mitgliedschaft beantragen" -> "Angebot bestellen": Mitgliedschaft aktiv
}
